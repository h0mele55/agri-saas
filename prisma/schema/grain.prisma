// ═══════════════════════════════════════════════════════════════════
//  ENTERPRISE-GRAIN DOMAIN — marketing contracts + harvest yield records
// ═══════════════════════════════════════════════════════════════════
//
//  GAP-09 multi-file schema: the large grain-producer persona. Generator
//  + datasource remain in base.prisma. Conventions mirror
//  planning.prisma / agriculture.prisma:
//    • cuid ids, createdAt/updatedAt, soft-delete trio
//      (deletedAt / deletedByUserId / retentionUntil — bare scalars).
//    • Cross-tenant barrier `@@unique([id, tenantId])`; child FKs are
//      composite `[xId, tenantId] → [id, tenantId]`.
//    • Every tenant-scoped table gets the canonical RLS trio
//      (tenant_isolation + tenant_isolation_insert + superuser_bypass +
//      FORCE) in the migration. Both models have NON-NULL tenantId, so
//      both use the standard split-policy form.
//
//  ── Plaintext vs encrypted (Epic B field-encryption manifest) ──
//  Commercially-sensitive FREE TEXT (negotiated terms, pricing rationale,
//  valuation commentary) is encrypted at rest via
//  `src/lib/security/encrypted-fields.ts`:
//      Contract.terms, Contract.pricingNotes, YieldRecord.valuationNotes
//  The NUMERIC magnitudes (volumeTonnes, pricePerTonne, grossTonnes,
//  moisturePct, areaHa) stay PLAINTEXT Decimals so the portfolio /
//  cost / yield rollups can aggregate them in-DB — an encrypted column
//  cannot be SUM()'d. Encrypted columns MUST be nullable String (the
//  middleware encrypts strings into the same column).
//
//  Back-relations added elsewhere (Prisma needs both sides):
//    • auth.prisma        Tenant:   contracts / yieldRecords
//    • agriculture.prisma Location: yieldRecords
//    • planning.prisma    Season:   contracts / yieldRecords
//    • planning.prisma    Planting: yieldRecords
// ═══════════════════════════════════════════════════════════════════

/// A grain marketing / supply contract — a forward SALE of produce or
/// PURCHASE of inputs with a counterparty. `volumeTonnes` +
/// `pricePerTonne` are plaintext (portfolio "contracted volume / value"
/// rollups SUM them); the negotiated `terms` + `pricingNotes` narrative
/// is encrypted at rest. Tenant-scoped.
model Contract {
  id              String         @id @default(cuid())
  tenantId        String
  /// Optional link to the marketing-year Season (portfolio rollup:
  /// contracted-vs-produced per season).
  seasonId        String?
  /// External contract reference / number.
  key             String?
  /// Buyer (SALE) or supplier (PURCHASE) name — plaintext, filterable.
  counterparty    String
  /// Commodity traded, e.g. "Wheat", "Malting Barley" — plaintext.
  commodity       String?
  type            ContractType   @default(SALE)
  status          ContractStatus @default(DRAFT)
  /// Contracted volume in metric tonnes — plaintext (SUM'd by rollups).
  volumeTonnes    Decimal?       @db.Decimal(14, 3)
  /// Agreed price per tonne — plaintext (contract value = volume × price).
  pricePerTonne   Decimal?       @db.Decimal(14, 2)
  priceCurrency   String?
  deliveryStart   DateTime?
  deliveryEnd     DateTime?
  /// ENCRYPTED (Epic B manifest) — full negotiated contract terms.
  terms           String?
  /// ENCRYPTED (Epic B manifest) — pricing basis / premium rationale.
  pricingNotes    String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  deletedAt       DateTime?
  deletedByUserId String?
  retentionUntil  DateTime?

  tenant Tenant  @relation(fields: [tenantId], references: [id])
  season Season? @relation(fields: [seasonId, tenantId], references: [id, tenantId])

  @@unique([id, tenantId])
  @@unique([tenantId, key])
  @@index([tenantId, status])
  @@index([tenantId, type])
  @@index([tenantId, seasonId])
  @@index([tenantId, deliveryStart])
}

/// An actual harvest production record — gross tonnes realised against a
/// Planting / field / Season, with the moisture basis + area for a t/ha
/// derivation. The detailed per-lot grain quality (test weight, protein,
/// per-lot moisture) lives on `InventoryLot.attributesJson`; this row is
/// the FIELD-level production total. Numeric magnitudes are plaintext
/// (yield rollups SUM them); only the commercial `valuationNotes` is
/// encrypted. Tenant-scoped.
model YieldRecord {
  id              String    @id @default(cuid())
  tenantId        String
  /// Optional link to the Planting whose harvest this realises.
  plantingId      String?
  /// Optional link to the field (Location) the produce came off.
  locationId      String?
  /// Optional link to the marketing-year Season.
  seasonId        String?
  /// Commodity harvested, e.g. "Wheat" — plaintext.
  commodity       String?
  harvestedAt     DateTime?
  /// Gross harvested mass in metric tonnes — plaintext (SUM'd by rollups).
  grossTonnes     Decimal?  @db.Decimal(14, 3)
  /// Moisture % at which grossTonnes was measured — plaintext.
  moisturePct     Decimal?  @db.Decimal(5, 2)
  /// Harvested area in hectares — plaintext (drives t/ha).
  areaHa          Decimal?  @db.Decimal(12, 4)
  /// ENCRYPTED (Epic B manifest) — commercial valuation commentary.
  valuationNotes  String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?
  deletedByUserId String?
  retentionUntil  DateTime?

  tenant   Tenant    @relation(fields: [tenantId], references: [id])
  planting Planting? @relation(fields: [plantingId, tenantId], references: [id, tenantId])
  location Location? @relation(fields: [locationId, tenantId], references: [id, tenantId])
  season   Season?   @relation(fields: [seasonId, tenantId], references: [id, tenantId])

  @@unique([id, tenantId])
  @@index([tenantId, plantingId])
  @@index([tenantId, locationId])
  @@index([tenantId, seasonId])
  @@index([tenantId, harvestedAt])
}
