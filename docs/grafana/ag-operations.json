{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "Prometheus datasource receiving OTel Collector metrics from inflect-compliance",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "annotations": { "list": [] },
  "description": "inflect-compliance — Ag Field Operations. Throughput, p95 latency vs the 1s SLO, failure ratio per ag usecase, weather-pull ingestion health, and audit-stream delivery.",
  "editable": true,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "type": "stat",
      "title": "Ag operation rate (5m)",
      "id": 1,
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "ops", "decimals": 2 } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum(rate(ag_operation_count_total[5m]))",
          "legendFormat": "ops/s",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Weather-pull p95 (5m)",
      "id": 2,
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5000 },
              { "color": "red", "value": 30000 }
            ]
          }
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "histogram_quantile(0.95, sum by (le)(rate(job_execution_duration_milliseconds_bucket{job_name=\"weather-pull\"}[5m])))",
          "legendFormat": "p95",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Weather-pull failure ratio (5m)",
      "id": 3,
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.01 },
              { "color": "red", "value": 0.05 }
            ]
          }
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum(rate(job_execution_count_total{job_name=\"weather-pull\",job_status=\"failure\"}[5m])) / clamp_min(sum(rate(job_execution_count_total{job_name=\"weather-pull\"}[5m])), 1e-9)",
          "legendFormat": "failure ratio",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Audit-stream delivery failures (5m)",
      "id": 4,
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "decimals": 3,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 0.0001 }
            ]
          }
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum(rate(audit_stream_delivery_failures_total[5m]))",
          "legendFormat": "failures/s",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Ag operation p95 duration per operation (SLO 1000ms)",
      "id": 5,
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": {
            "thresholdsStyle": { "mode": "line" }
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1000 }
            ]
          }
        }
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "histogram_quantile(0.95, sum by (le, ag_operation) (rate(ag_operation_duration_milliseconds_bucket[5m])))",
          "legendFormat": "{{ag_operation}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Ag operation failure ratio per operation",
      "id": 6,
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.01 },
              { "color": "red", "value": 0.05 }
            ]
          }
        }
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum by (ag_operation)(rate(ag_operation_count_total{ag_outcome=\"failure\"}[5m])) / clamp_min(sum by (ag_operation)(rate(ag_operation_count_total[5m])), 1e-9)",
          "legendFormat": "{{ag_operation}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Weather-pull job duration p95",
      "id": 7,
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 13 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "ms" } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "histogram_quantile(0.95, sum by (le)(rate(job_execution_duration_milliseconds_bucket{job_name=\"weather-pull\"}[5m])))",
          "legendFormat": "weather-pull p95",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Weather-pull failure ratio",
      "id": 8,
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 13 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.01 },
              { "color": "red", "value": 0.05 }
            ]
          }
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum(rate(job_execution_count_total{job_name=\"weather-pull\",job_status=\"failure\"}[5m])) / clamp_min(sum(rate(job_execution_count_total{job_name=\"weather-pull\"}[5m])), 1e-9)",
          "legendFormat": "failure ratio",
          "refId": "A"
        }
      ]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "style": "dark",
  "tags": ["inflect-compliance", "agriculture"],
  "templating": { "list": [] },
  "time": { "from": "now-3h", "to": "now" },
  "timepicker": {},
  "timezone": "",
  "title": "inflect-compliance — Ag Field Operations",
  "uid": "inflect-ag-operations",
  "version": 1,
  "weekStart": ""
}
